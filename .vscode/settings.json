{
    "python.testing.pytestEnabled": true,
    "python.testing.pytestArgs": [
        "-v",
        "-s",
        "--ignore=base-hack",
        "${workspaceFolder}/tests"
    ],
    "python.testing.unittestEnabled": false,
    "python.analysis.typeshedPaths": [
        ".venv/Lib/site-packages",
        "typings"
    ],
    "files.associations": {
        "*.code": "c",
        "common.h": "c",
        "xtree": "c",
        "tuple": "c",
        "type_traits": "c",
        "utility": "c",
        "xutility": "c",
        "common_enums.h": "c",
        "dynamic_structs.h": "c",
        "common_structs.h": "c",
        "libaudio.h": "c",
        "initializer_list": "c",
        "list": "c",
        "vector": "c",
        "xstring": "c",
        "xlocale": "c",
        "algorithm": "c",
        "iterator": "c",
        "memory": "c",
        "compare": "c",
        "xmemory": "c",
        "xtr1common": "c",
        "pause.h": "c",
        "crowd_control.h": "c",
        "archipelago.h": "c"
    },
    "files.watcherExclude": {
        "**/.git/**": true,
        "**/build/armips/**": true,
        "**/build/libdragon/**": true,
        "**/build/n64chain/**": true,
        "**/out/**": true,
        "**/dist/**": true,
        "**/node_modules/**": true,
        "**/*.o": true,
        "**/*.a": true,
        "**/*.elf": true,
        "**/*.bin": true,
        "**/*.z64": true,
        "**/*.n64": true,
        "**/*.rom": true
    },
    "search.exclude": {
        "**/.git/**": true,
        "**/build/armips/**": true,
        "**/build/libdragon/**": true,
        "**/build/n64chain/**": true,
        "**/*.o": true,
        "**/*.elf": true,
        "**/*.bin": true,
        "**/*.z64": true
    },
    "window.commandCenter": false,
    "editor.largeFileOptimizations": true,
    "files.maxMemoryForLargeFilesMB": 16,
    "typescript.disableAutomaticTypeAcquisition": true
}
